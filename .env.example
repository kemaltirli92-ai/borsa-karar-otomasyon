# XK100 Borsa Karar Otomasyonu — .env ornegi (GERCEK DEGERLER YAZILMAZ)
# Bu dosyayi .env olarak kopyalayip VPS uzerinde doldurun. .env ASLA repoya eklenmez.

# Telegram (ileride aktif edilecek — su an pasif entegrasyon)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Yonetici API token (X-Admin-Token)
ADMIN_TOKEN=

# Veri kaynaklari (BLOK 8: ana kaynak lisansli API)
LICENSED_PRICE_API_KEY=
LICENSED_PRICE_API_URL=

# KAP (BLOK 11: merkezi akis ucu)
KAP_FEED_URL=

# Veri tabani (BLOK 7)
DATABASE_PATH=/opt/borsa-karar-otomasyon/db/xk100.db

# Log seviyesi
LOG_LEVEL=INFO
